{
  "enabled": true,
  "name": "Auto Push a GitHub",
  "description": "Hace git add, commit y push automáticamente cada vez que se guarda un archivo",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.html",
      "*.css",
      "*.js"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "git add . && git commit -m \"auto: actualización\" && git push origin main"
  }
}